   "source": [
    "# Nhập dữ liệu\n",
    "t = int(input('Nhap vao tong so giay: '))\n",
    "# Xử lý\n",
    "\n",
    "hh = t // 3600\n",
    "mm = (t % 3600) // 60\n",
    "ss = t % 60\n",
    "\n",
    "# Xuất dữ liệu\n",
    "print(f'{t} giay co dang {hh}:{mm}:{ss}')"
   ]
  }
